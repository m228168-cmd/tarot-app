{
  "name": "ai-auto-editor",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "drive:list": "node scripts/drive/list-files.js",
    "drive:scan": "node scripts/pipeline/scan-drive.js",
    "drive:download": "node scripts/drive/download-file.js",
    "pipeline:download-latest": "node scripts/pipeline/download-latest.js",
    "pipeline:download-latest:task": "node scripts/pipeline/run-task.js download-latest --summary \"下載最新未處理素材\" --note \"透過 task runner 記錄實際下載結果\" -- npm run pipeline:download-latest",
    "task:run": "node scripts/pipeline/run-task.js",
    "task:report": "node scripts/pipeline/task-report.js",
    "task:status": "node scripts/pipeline/task-status.js",
    "pipeline:transcribe": "node scripts/pipeline/transcribe.js",
    "pipeline:artifacts": "node scripts/pipeline/generate-artifacts.js",
    "pipeline:export-highlight": "node scripts/pipeline/export-highlight.js",
    "pipeline:export-rough-cut": "node scripts/pipeline/export-rough-cut.js",
    "pipeline:export-short": "node scripts/pipeline/export-short-highlight.js",
    "pipeline:batch-shorts": "node scripts/pipeline/batch-shorts.js",
    "pipeline:rerun": "node scripts/pipeline/rerun-from-review.js",
    "memes:bootstrap": "node scripts/pipeline/bootstrap-memes.js"
  },
  "dependencies": {
    "@google-cloud/local-auth": "^3.0.1",
    "dotenv": "^17.4.1",
    "googleapis": "^171.4.0",
    "openai": "^6.33.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "vite": "^8.0.1"
  }
}
